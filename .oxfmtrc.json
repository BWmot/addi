{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": ["dist/", "out/", "node_modules/", "typings/", "*.vsix", "bun.lock"]
}
