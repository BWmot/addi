{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["vscode", "mocha", "node"],
    "noImplicitAny": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts"]
}
